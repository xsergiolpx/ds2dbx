# Databricks notebook source

# MAGIC %md
# MAGIC # Data Loader: Load CSV files into Delta tables
# MAGIC
# MAGIC **Catalog:** `{{ catalog }}`
# MAGIC **Schema:** `{{ schema }}`
# MAGIC **Volume path:** `{{ volume_path }}`

# COMMAND ----------

spark.sql("USE CATALOG {{ catalog }}")
spark.sql("USE SCHEMA {{ schema }}")

# COMMAND ----------

# MAGIC %md
# MAGIC ## Load tables
{% for table in tables %}

# COMMAND ----------

# MAGIC %md
# MAGIC ### {{ table.table_name }}
# MAGIC Source file: `{{ table.filename }}`

# COMMAND ----------

df = (
    spark.read
    .option("header", "{{ 'true' if table.has_header else 'false' }}")
    .option("inferSchema", "true")
    .option("sep", "{{ table.delimiter }}")
    .csv("{{ table.file_path }}")
)
print("{{ table.table_name }}: " + str(df.count()) + " rows, " + str(len(df.columns)) + " columns")
df.write.mode("overwrite").saveAsTable("{{ catalog }}.{{ schema }}.{{ table.table_name }}")

{% endfor %}
# COMMAND ----------

# MAGIC %md
# MAGIC ## Verification

# COMMAND ----------

print("=== Loaded Tables ===")
{% for table in tables %}
cnt = spark.sql("SELECT COUNT(*) AS cnt FROM {{ catalog }}.{{ schema }}.{{ table.table_name }}").collect()[0]["cnt"]
print("{{ table.table_name }}: " + str(cnt) + " rows")
{% endfor %}
print("=== Done ===")
